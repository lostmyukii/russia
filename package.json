{
  "name": "russian-wordscodex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @russian-wordscodex/web dev",
    "dev:api": "pnpm --filter @russian-wordscodex/api dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @russian-wordscodex/web test:e2e",
    "db:validate": "pnpm --filter @russian-wordscodex/api db:validate",
    "db:migrate": "pnpm --filter @russian-wordscodex/api db:migrate",
    "db:deploy": "pnpm --filter @russian-wordscodex/api db:deploy",
    "db:seed": "pnpm --filter @russian-wordscodex/api db:seed",
    "vocabulary:generate": "pnpm --filter @russian-wordscodex/import-vocabulary generate:domain",
    "vocabulary:validate": "pnpm --filter @russian-wordscodex/import-vocabulary validate",
    "release:check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm db:validate && pnpm vocabulary:validate scripts/import-vocabulary/fixtures/pep-russian-sample.csv && pnpm test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
